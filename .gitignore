###########################################################################
# WinMinimal
#
# Git ignore file
#
# Ignore runtime-generated files while keeping the project structure.
###########################################################################

###########################################################################
# Runtime folders
###########################################################################
Logs/*
!Logs/.gitkeep

Backup/*
!Backup/.gitkeep

###########################################################################
# Generated files
###########################################################################
*.log
*.tmp
*.temp
*.bak
*.old

###########################################################################
# Windows
###########################################################################
Thumbs.db
Desktop.ini

###########################################################################
# Visual Studio Code
###########################################################################
.vscode/

###########################################################################
# JetBrains IDEs
###########################################################################
.idea/

###########################################################################
# PowerShell
###########################################################################
ConsoleHost_history.txt

###########################################################################
# OS generated files
###########################################################################
.DS_Store
