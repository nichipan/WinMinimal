###############################################################################
#
# WinMinimal
#
# Git Attributes
#
# Enforce consistent line endings across platforms.
#
###############################################################################

# -----------------------------------------------------------------------------
# Default text handling
# -----------------------------------------------------------------------------

* text=auto

# -----------------------------------------------------------------------------
# PowerShell
# -----------------------------------------------------------------------------

*.ps1   text eol=lf
*.psm1  text eol=lf
*.psd1  text eol=lf

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------

*.md    text eol=lf
*.txt   text eol=lf

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------

*.json  text eol=lf
*.xml   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# -----------------------------------------------------------------------------
# Binary files
# -----------------------------------------------------------------------------

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary